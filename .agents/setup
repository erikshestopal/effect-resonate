#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

export VP_NODE_MANAGER=yes
export PATH="$HOME/.vite-plus/bin:$HOME/.local/bin:$PATH"

if [ ! -x "$HOME/.vite-plus/bin/vp" ]; then
  curl -fsSL https://vite.plus | bash
else
  vp env setup --refresh
fi

vp install --frozen-lockfile --ignore-scripts
bunx --bun effect-tsgo patch
bun install --cwd repos/resonate-sdk-ts --ignore-scripts

install_resonate() {
  local version="v0.9.8"

  install_resonate_from_source() {
    export CARGO_HOME="$HOME/.cargo"
    export RUSTUP_HOME="$HOME/.rustup"
    export PATH="$CARGO_HOME/bin:$PATH"

    if ! command -v cargo >/dev/null 2>&1; then
      curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable
      . "$CARGO_HOME/env"
    fi

    cargo install --git https://github.com/resonatehq/resonate --tag "$version" --locked --root "$HOME/.local" resonate
  }

  local arch
  case "$(uname -m)" in
    x86_64 | amd64) arch="x86_64" ;;
    aarch64 | arm64) arch="aarch64" ;;
    *)
      echo "Unsupported architecture for resonate CLI: $(uname -m)" >&2
      return 1
      ;;
  esac

  local artifact="resonate_linux_${arch}.tar.gz"
  local base="https://github.com/resonatehq/resonate/releases/download/${version}/${artifact}"
  local tmp
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' RETURN

  mkdir -p "$HOME/.local/bin"
  curl -fsSL "$base" -o "$tmp/$artifact"
  curl -fsSL "${base}.sha256" -o "$tmp/${artifact}.sha256"
  (cd "$tmp" && sha256sum -c "${artifact}.sha256")
  tar -xzf "$tmp/$artifact" -C "$tmp"
  find "$tmp" -type f -name resonate -perm /111 -exec cp {} "$HOME/.local/bin/resonate" \;
  chmod +x "$HOME/.local/bin/resonate"

  if ! "$HOME/.local/bin/resonate" --help >/dev/null 2>&1; then
    rm -f "$HOME/.local/bin/resonate"
    install_resonate_from_source
  fi
}

if ! command -v resonate >/dev/null 2>&1 || ! resonate --help >/dev/null 2>&1; then
  install_resonate
fi
